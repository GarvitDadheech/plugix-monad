# ─── Privy ───────────────────────────────────────────────────────────────────
# Get these from https://dashboard.privy.io → your app → Settings

NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# Authorization key for server-side wallet signing (key quorum)
#
# 1. Generate a P-256 key pair:
#      openssl ecparam -name prime256v1 -genkey -noout -out private.pem
#      openssl ec -in private.pem -pubout -out public.pem
#
# 2. In the Privy Dashboard → Settings → Authorization Keys → Add Key:
#      Paste the contents of public.pem. Save the Key-Quorum ID below.
#
# 3. Set PRIVY_AUTHORIZATION_KEY to the contents of private.pem.
#    Use single quotes so the newlines are preserved, e.g.:
#
#      PRIVY_AUTHORIZATION_KEY='-----BEGIN EC PRIVATE KEY-----
#      MHQCAQEEIBp...
#      -----END EC PRIVATE KEY-----'
#
#    Alternatively: openssl pkcs8 -topk8 -nocrypt -in private.pem | base64 -w0
#    gives you bare base64 which also works (no quotes needed).

PRIVY_AUTHORIZATION_KEY=
PRIVY_KEY_QUORUM_ID=

# ─── Postgres (matches docker-compose.yml defaults) ───────────────────────────
DATABASE_URL=postgresql://plugix:plugix@localhost:5432/plugix

# ─── MCP Callback ────────────────────────────────────────────────────────────
# Shared secret between the MCP server and this backend.
MCP_CALLBACK_SECRET=change-me-in-production

# ─── Chain ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CHAIN=monad-devnet

# ─── Optional ────────────────────────────────────────────────────────────────
# Address that receives platform fees on-chain.
# PLATFORM_RECEIVER_ADDRESS=0x...
